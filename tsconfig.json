{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./lib",
    "target": "es2025",
    "moduleResolution": "bundler",
    "declaration": true,
    "stripInternal": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src", ".astro/types.d.ts"]
}
